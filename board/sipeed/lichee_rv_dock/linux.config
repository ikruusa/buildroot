# Minimal Linux config for Sipeed Lichee RV Dock (Allwinner D1)
# Minimal config for SD card boot - no audio, DRM, WiFi, etc.

# Base
CONFIG_SYSVIPC=y
CONFIG_HIGH_RES_TIMERS=y
CONFIG_BPF_SYSCALL=y
CONFIG_IKCONFIG=y
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_USER_NS=y
CONFIG_BLK_DEV_INITRD=y

# RISC-V arch
CONFIG_ARCH_SUNXI=y
CONFIG_MMC=y
CONFIG_SMP=y
CONFIG_JUMP_LABEL=y
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y

# Networking (minimal for boot)
CONFIG_NET=y
CONFIG_PACKET=y

# Block layer
CONFIG_BLK_DEV_THROTTLING=y

# PCI (not needed for D1 boot, keep minimal)
CONFIG_PCI=y

# Device drivers
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Block devices
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_SD=y

# MMC/SD
CONFIG_MMC=y
CONFIG_MMC_SUNXI=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BLOCK_MINORS=8

# Input
CONFIG_INPUT_EVDEV=y
CONFIG_KEYBOARD_GPIO=y

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_DW=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y

# GPIO
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y

# Power
CONFIG_POWER_RESET=y
CONFIG_POWER_RESET_GPIO_RESTART=y
CONFIG_SUNXI_WATCHDOG=y

# Regulators
CONFIG_REGULATOR=y
CONFIG_REGULATOR_FIXED_VOLTAGE=y
CONFIG_REGULATOR_GPIO=y

# PM
CONFIG_PM=y
CONFIG_PM_SLEEP=y
CONFIG_PM_DEVFREQ=y

# Clocks
CONFIG_SUNXI_CCU=y

# Pin control
CONFIG_PINCTRL=y
CONFIG_PINCTRL_SUNXI=y

# RTC
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_SUN6I=y

# DMA
CONFIG_DMADEVICES=y
CONFIG_DMA_SUN6I=y

# IOMMU
CONFIG_SUN50I_IOMMU=y

# NVMEM
CONFIG_NVMEM=y
CONFIG_NVMEM_SUNXI_SID=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_POSIX_ACL=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_HUGETLBFS=y
CONFIG_AUTOFS_FS=y
CONFIG_MSDOS_FS=y
CONFIG_VFAT_FS=y

# NLS
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# Kernel features
CONFIG_PRINTK_TIME=y
CONFIG_DEBUG_KERNEL=y
CONFIG_DEBUG_FS=y

# SBI
CONFIG_RISCV_SBI=y

# CPU Frequency
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_STAT=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPUFREQ_DT=y

# Timer
CONFIG_RISCV_TIMER=y
CONFIG_SUNXI_TIMER=y
# CONFIG_SCHED_HRTICK is not set
CONFIG_HZ_PERIODIC=y
CONFIG_HZ_250=y
